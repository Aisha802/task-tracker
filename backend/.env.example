# Copy this file to .env and adjust as needed.

# SQLite is the default and needs no extra setup.
DATABASE_URL=sqlite:///./tasktracker.db

# Generate your own secret, e.g.: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Comma-separated list of origins allowed to call this API (your frontend URL(s))
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
